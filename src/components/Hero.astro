<section class="hero" id="hero">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="hero-badge intro-item" style="--i:0">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V5l-8-3z"/><path class="tick" d="m9 12 2 2 4-4"/></svg>
        Sistema Integral de Movilidad
      </p>
      <h1 class="intro-item" style="--i:1">Tu moto de trabajo, <strong>sin bancos</strong> y en cuotas que podés pagar.</h1>
      <p class="lead intro-item" style="--i:2">SIMO es el sistema de leasing que te da la herramienta para crecer: la usás para trabajar desde el día uno y la vas haciendo tuya, con evaluación simple y costos claros.</p>
      <div class="hero-cta intro-item" style="--i:3">
        <a href="#calculadora" class="btn btn-lg">Simulá tu cuota
          <svg class="arr" viewBox="0 0 24 24" aria-hidden="true"><path d="M5.06 11.57h13.76M13.5 5l6.5 6.5-6.5 6.5"/></svg>
        </a>
        <a href="#contacto" class="btn btn-outline btn-lg">
          <svg class="wsp-ico" viewBox="0 0 32 32" aria-hidden="true"><path d="M16 3C9.4 3 4 8.4 4 15c0 2.1.6 4.2 1.6 6L4 29l8.2-1.6c1.7.9 3.7 1.4 5.8 1.4 6.6 0 12-5.4 12-12S22.6 3 16 3zm0 21.8c-1.8 0-3.5-.5-5-1.4l-.4-.2-4.3.9.9-4.2-.3-.4c-1-1.6-1.5-3.4-1.5-5.3C5.4 9.6 10 5 16 5s10.6 4.6 10.6 10.6S22 24.8 16 24.8zm5.8-7.9c-.3-.2-1.9-.9-2.2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-1.8-.9-3-1.6-4.2-3.6-.3-.5.3-.5.9-1.6.1-.2 0-.4 0-.5l-1-2.3c-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.2 3.4 5.4 4.7 2 .9 2.8.9 3.8.8.6-.1 1.9-.8 2.2-1.5.3-.7.3-1.4.2-1.5-.1-.2-.3-.3-.6-.4z"/></svg>
          Hablar con un asesor
        </a>
      </div>
      <ul class="hero-trust intro-item" style="--i:4">
        <li><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Respuesta en 48 h</li>
        <li><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Sin perfil crediticio perfecto</li>
        <li><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Costos 100% transparentes</li>
      </ul>
    </div>

    <div class="hero-visual intro-item" style="--i:2">
      <svg class="hero-route" viewBox="0 0 520 520" fill="none" aria-hidden="true">
        <path class="route-path" d="M60 460 C 140 420, 100 300, 200 280 S 380 320, 420 220 S 380 90, 460 60" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="1 14"/>
        <circle class="route-dot" cx="60" cy="460" r="6" fill="currentColor"/>
        <circle class="route-dot end" cx="460" cy="60" r="6" fill="currentColor"/>
      </svg>
      <div class="hero-photo">
        <img src="/img/moto.webp"
             srcset="/img/moto-800.webp 800w, /img/moto.webp 1500w"
             sizes="(max-width: 1024px) 92vw, 45vw"
             width="1500" height="1000"
             fetchpriority="high" decoding="async"
             alt="Moto SIMO lista para trabajar" />
      </div>
      <div class="hero-chip chip-approved" aria-hidden="true">
        <span class="chip-ico">
          <svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
        </span>
        <span>
          <strong>Solicitud aprobada</strong>
          <small>Plan a tu medida en 48 h</small>
        </span>
      </div>
      <div class="hero-chip chip-growth" aria-hidden="true">
        <span class="chip-ico chip-ico-nav">
          <svg viewBox="0 0 24 24"><path d="M3 17 9 11l4 4 8-8"/><path d="M14 7h7v7"/></svg>
        </span>
        <span>
          <strong>Hasta 2,5× más entregas</strong>
          <small>con tu propia movilidad</small>
        </span>
      </div>
    </div>
  </div>

  <div class="stats reveal" id="stats">
    <div class="stat">
      <span class="stat-num" data-count="9">0</span>
      <span class="stat-label">Agencias en el país</span>
    </div>
    <div class="stat">
      <span class="stat-num" data-count="48" data-suffix=" h">0 h</span>
      <span class="stat-label">Respuesta promedio</span>
    </div>
    <div class="stat">
      <span class="stat-num" data-count="2.5" data-decimals="1" data-suffix="×">0×</span>
      <span class="stat-label">Más entregas por día*</span>
    </div>
    <div class="stat">
      <span class="stat-num" data-count="100" data-suffix="%">0%</span>
      <span class="stat-label">Costos transparentes</span>
    </div>
  </div>
</section>
