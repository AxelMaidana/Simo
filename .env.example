# Copiá este archivo a ".env" y completá con tus credenciales de EmailJS
# (https://dashboard.emailjs.com/admin) para que el formulario del simulador
# pueda enviar el lead por correo. En Netlify, configurá estas mismas
# variables en Site configuration > Environment variables.

PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=
